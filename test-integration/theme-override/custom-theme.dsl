styles {
    element "Component" {
        shape Component
        background #85C1E2
        color #000000
    }
    element "Code" {
        background #d4e8fc
        color #000000
        shape RoundedBox
    }
    element "Person" {
        shape Person
        background #08427B
        color #FFFFFF
    }
    relationship "Relationship" {
        color #707070
        style dashed
    }
}
